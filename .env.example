# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret-key

# ── IBM Watsonx AI ──────────────────────────────────────────
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your-watsonx-api-key-here

# Obtain from your Watsonx project settings
WATSONX_PROJECT_ID=your-watsonx-project-id-here

# Regional endpoint (default: us-south)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model identifier to use for chat completions
WATSONX_MODEL_ID=ibm/granite-4-h-small

# ── Dataset ─────────────────────────────────────────────────
# Path to the college CSV dataset (leave blank to use default)
DATASET_PATH=
